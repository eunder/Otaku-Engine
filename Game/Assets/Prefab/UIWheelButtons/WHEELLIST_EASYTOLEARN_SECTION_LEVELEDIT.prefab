  m_Script: {fileID: 11500000, guid: 63ba9a846ffc02649ab02e95120c8d55, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  ObjectName: Light
  objectTips:
  - Try not to have too many lights in a map
  - For outdoor scenes, try to have a directional light
  - For indoor scenes, use smart point/spot lighting
  - Remember, lights reflect the colors of the objects they are hitting
  - Shadows =  cool/blue
  - Lit areas = warm/yellow
